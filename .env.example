# --- Base de données : PostgreSQL (Neon) ---
# Runtime (connexion POOLÉE — host avec "-pooler") : recommandée pour Vercel
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Migrations / db push (connexion DIRECTE — sans "-pooler")
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# --- Sessions (cookie signé) ---
SESSION_SECRET=changez_moi_en_production

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=EduWeb <activation@votre-domaine>

# --- Application ---
# En production, mettre l'URL publique (ex. https://eduweb.vercel.app)
BASE_URL=http://localhost:3000
NODE_ENV=development
