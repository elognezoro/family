# --- Base de données : PostgreSQL (Neon) ---
# Runtime (connexion POOLÉE — host avec "-pooler") : recommandée pour Vercel
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Migrations / db push (connexion DIRECTE — sans "-pooler")
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# --- Sessions (cookie signé) ---
SESSION_SECRET=changez_moi_en_production

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=EduWeb <activation@votre-domaine>

# --- SMS (notifications : réservations, missions, nouveaux messages) ---
# Le fournisseur est auto-détecté. Sans configuration, les SMS sont écrits dans les logs.
# Option A — Twilio :
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_FROM=+225xxxxxxxx
# Option B — Passerelle HTTP (agrégateur local). {to} et {text} sont remplacés.
# SMS_GATEWAY_URL=https://api.mon-agregateur.ci/send?to={to}&msg={text}&from=EduWeb
# SMS_GATEWAY_METHOD=GET            # ou POST (corps JSON {to,text} si l'URL n'a pas de {to}/{text})
# SMS_GATEWAY_AUTH=Bearer xxxxxxxx  # en-tête Authorization optionnel

# --- Stockage des fichiers (Vercel Blob) ---
# Créez un store Blob dans Vercel (Storage → Create → Blob) : le token est injecté
# automatiquement en production. En local, copiez-le ici pour tester le cloud.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx

# --- Application ---
# En production, mettre l'URL publique (ex. https://eduweb.vercel.app)
BASE_URL=http://localhost:3000
NODE_ENV=development

# --- Cron (purge des pièces jointes > 1 mois) ---
# Défini → l'endpoint /api/cron/purge-attachments n'accepte que les appels Vercel Cron
# (en-tête Authorization: Bearer <CRON_SECRET>, ajouté automatiquement par Vercel).
CRON_SECRET=changez_moi
