<%
  var roleLabel = { parent: t('auth.roleParent'), coach: t('auth.roleCoach'), commercial: t('auth.roleCommercial'), admin: t('role.admin') };
  var typeLabel = { parent_payment: t('ref.typePaid'), coach_accept: t('ref.typeAccepted') };
%>
<section class="container space">
  <div class="space__head">
    <div>
      <h1 class="space__title"><%- icon('cash', 26) %> <%= isCommercial ? t('ref.commercialSpace') : t('menu.referral') %></h1>
      <p class="space__sub"><%- t('ref.subtitle') %></p>
    </div>
  </div>

  <!-- KPIs -->
  <div class="kpi-grid">
    <div class="kpi"><div class="kpi__icon kpi__icon--green"><%- icon('users', 22) %></div><div><div class="kpi__value"><%= data.referrals.length %></div><div class="kpi__label"><%= t('ref.referralsCount') %></div></div></div>
    <div class="kpi"><div class="kpi__icon kpi__icon--green"><%- icon('graduation', 22) %></div><div><div class="kpi__value"><%= data.commissions.length %></div><div class="kpi__label"><%= t('ref.completedMissions') %></div></div></div>
    <div class="kpi"><div class="kpi__icon kpi__icon--amber"><%- icon('cash', 22) %></div><div><div class="kpi__value"><%= APP.formatFCFA(data.total) %></div><div class="kpi__label"><%= t('ref.earnings') %> · ≈ <%= APP.formatEUR(data.total) %></div></div></div>
  </div>

  <% if (isCommercial) { %><%- include('partials/dash-tools') %><% } %>

  <!-- Lien d'invitation -->
  <div class="panel">
    <div class="panel__head"><h2><%- icon('users', 20) %> <%= t('ref.myLink') %></h2></div>
    <div class="invite-link">
      <input type="text" id="inviteLink" value="<%= data.link %>" readonly>
      <button type="button" class="btn btn--primary" data-copy="#inviteLink"><%- icon('doc', 16) %> <%= t('ref.copy') %></button>
    </div>
    <p class="muted mt"><%= t('ref.codeLabel') %> <strong><%= data.code %></strong>. <%- t('ref.linkExplain') %></p>
    <div class="invite-share mt">
      <a class="btn btn--ghost btn--sm" target="_blank" rel="noopener" href="https://wa.me/?text=<%= encodeURIComponent(t('ref.inviteMsg') + data.link) %>"><%- icon('phone', 14) %> <%= t('ref.shareWhatsApp') %></a>
      <a class="btn btn--ghost btn--sm" href="mailto:?subject=<%= encodeURIComponent(t('ref.inviteSubject')) %>&body=<%= encodeURIComponent(t('ref.inviteBody') + data.link) %>"><%- icon('mail', 14) %> <%= t('ref.shareEmail') %></a>
    </div>
  </div>

  <!-- Filleuls -->
  <div class="panel">
    <div class="panel__head"><h2><%- icon('users', 20) %> <%= t('ref.myReferrals') %></h2><span class="badge badge--soft"><%= data.referrals.length %></span></div>
    <% if (!data.referrals.length) { %>
      <div class="empty"><%- icon('users', 36) %><p><%= t('ref.noReferral') %></p></div>
    <% } else { %>
      <div class="table-wrap">
        <table class="table">
          <thead><tr><th><%= t('ref.referral') %></th><th><%= t('auth.accountType') %></th><th><%= t('ref.registeredOn') %></th></tr></thead>
          <tbody>
            <% data.referrals.forEach(function(r){ %>
              <tr>
                <td><strong><%= r.name %></strong></td>
                <td><span class="badge badge--soft"><%= roleLabel[r.role] || r.role %></span></td>
                <td class="muted"><%= new Date(r.createdAt).toLocaleDateString('fr-FR') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- Missions abouties & gains -->
  <div class="panel">
    <div class="panel__head"><h2><%- icon('cash', 20) %> <%= t('ref.missionsEarnings') %></h2><span class="badge badge--ok"><%= t('ref.total') %> : <%= APP.formatFCFA(data.total) %></span></div>
    <% if (!data.commissions.length) { %>
      <div class="empty"><%- icon('cash', 36) %><p><%= t('ref.noEarning') %></p></div>
    <% } else { %>
      <div class="table-wrap">
        <table class="table">
          <thead><tr><th><%= t('common.date') %></th><th><%= t('ref.referral') %></th><th><%= t('th.action') %></th><th><%= t('ref.yourCommission') %></th><th><%= t('ref.settlement') %></th></tr></thead>
          <tbody>
            <% data.commissions.forEach(function(c){ %>
              <tr>
                <td class="muted"><%= new Date(c.createdAt).toLocaleDateString('fr-FR') %></td>
                <td><%= data.nameById[c.refereeUserId] || '—' %></td>
                <td><%= typeLabel[c.type] || c.type %></td>
                <td><strong><%= APP.formatFCFA(c.amount) %></strong> <span class="muted">≈ <%= APP.formatEUR(c.amount) %></span></td>
                <td><% if (c.paid) { %><span class="badge badge--ok"><%= t('ref.paid') %></span><% } else { %><span class="badge badge--pending"><%= t('status.pending') %></span><% } %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</section>
