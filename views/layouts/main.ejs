<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'fr' %>" dir="<%= typeof dir !== 'undefined' ? dir : 'ltr' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="EduWeb — Plateforme de mise en relation entre familles et coachs scolaires en Côte d'Ivoire.">
  <title><%= title %></title>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,900&family=Schibsted+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- Drapeaux SVG -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.2.3/css/flag-icons.min.css">

  <!-- Leaflet (cartographie) -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">

  <link rel="stylesheet" href="/css/style.css?v=<%= v('css/style.css') %>">
  <link rel="icon" href="/images/logo.svg" type="image/svg+xml">

  <!-- PWA (application installable) -->
  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="theme-color" content="#1E9E57">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="EduWeb">
  <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png">
</head>
<body class="<%= bodyClass %>">

  <% if (!hideChrome) { %>
    <%- include('../partials/header') %>
  <% } %>

  <% if (locals.mt && locals.mm) { %>
    <div class="flash-wrap" id="flash">
      <div class="flash flash--<%= mt %>">
        <span class="flash__icon"><%- icon(mt === 'success' ? 'check' : mt === 'error' ? 'x' : 'bell', 18) %></span>
        <span><%- mm %></span>
        <button class="flash__close" onclick="document.getElementById('flash').remove()" aria-label="Fermer">&times;</button>
      </div>
    </div>
  <% } %>

  <main class="main">
    <%- body %>
  </main>

  <% if (!hideChrome) { %>
    <%- include('../partials/footer') %>
  <% } %>

  <% if (currentUser && !currentPath.startsWith('/messages') && currentPath !== '/guides') { %>
    <a href="/guides" class="help-fab <%= currentPath === '/' ? 'help-fab--raised' : '' %>" aria-label="Aide" title="<%= currentUser.isSuperAdmin ? 'Guides d\'utilisation' : 'Guide d\'utilisation' %>">
      <%- icon('book', 22) %><span class="help-fab__label"><%= t('fab.help') %></span>
    </a>
  <% } %>

  <% if (currentPath === '/') { %>
    <a href="https://booking.eduweb.ci/certel/diagnostic" class="certel-fab" target="_blank" rel="noopener"
       aria-label="<%= t('fab.certelTitle') %> — CERTEL">
      <span class="certel-fab__icon"><%- icon('graduation', 20) %></span>
      <span class="certel-fab__text">
        <span class="certel-fab__title"><%= t('fab.certelTitle') %></span>
        <span class="certel-fab__sub"><%= t('fab.certelSub') %></span>
      </span>
    </a>
  <% } %>

  <script>
    window.EDUWEB_COUNTRIES = <%- JSON.stringify(countryGroups) %>;
    window.EDUWEB_DIALCODES = <%- JSON.stringify(dialCodes) %>;
    window.EDUWEB_EUR_RATE = <%= APP.EUR_RATE %>;
    window.EDUWEB_I18N = { perMonth: <%- JSON.stringify(t('cdash.perMonth')) %>, you: <%- JSON.stringify(t('cprofil.you')) %>, tocTitle: <%- JSON.stringify(t('toc.title')) %> };
  </script>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="/js/app.js?v=<%= v('js/app.js') %>"></script>
  <script src="/js/country-picker.js?v=<%= v('js/country-picker.js') %>"></script>
  <script src="/js/zone-intervention.js?v=<%= v('js/zone-intervention.js') %>"></script>

  <!-- PWA : enregistrement du service worker -->
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', function () {
        navigator.serviceWorker.register('/sw.js').catch(function (err) {
          console.warn('SW registration failed:', err);
        });
      });
    }
  </script>
</body>
</html>
