<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand brand--header">
      <img src="/images/logo.svg" alt="EduWeb" class="brand__logo" onerror="this.style.display='none'">
    </a>

    <button class="nav-toggle" id="navToggle" aria-label="Menu">
      <%- icon('menu', 24) %>
    </button>

    <nav class="site-nav" id="siteNav">
      <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Accueil</a>
      <a href="/#ouvrages">Nos ouvrages</a>
      <a href="/tarifs" class="<%= currentPath === '/tarifs' ? 'active' : '' %>">Tarifs</a>
      <a href="/a-propos" class="<%= currentPath === '/a-propos' ? 'active' : '' %>">À propos</a>

      <% if (currentUser) { %>
        <%
          function avatarInner() {
            if (currentUserPhoto) return '<img src="' + currentUserPhoto + '" alt="">';
            return (currentUser.name || '?').charAt(0);
          }
        %>
        <div class="user-menu" id="userMenu">
          <button type="button" class="user-menu__trigger" id="userMenuBtn" aria-haspopup="true" aria-expanded="false" aria-label="Mon menu">
            <span class="nav-user__avatar"><%- avatarInner() %></span>
            <%- icon('chevronDown', 16) %>
          </button>
          <div class="user-menu__dropdown" id="userMenuDropdown" hidden>
            <div class="user-menu__head">
              <span class="nav-user__avatar nav-user__avatar--lg"><%- avatarInner() %></span>
              <div class="user-menu__id">
                <strong><%= currentUser.name %></strong>
                <span class="muted"><%= currentUser.email %></span>
                <span class="badge badge--soft"><%= currentUser.role %></span>
              </div>
            </div>

            <div class="user-menu__links">
              <a href="/<%= currentUser.role %>"><%- icon('dashboard', 16) %> Mon espace</a>

              <% if (currentUser.role === 'admin') { %>
                <% if (currentUser.isSuperAdmin) { %>
                  <a href="/admin/admins"><%- icon('shield', 16) %> Administrateurs</a>
                <% } %>
                <% if (APP.hasPerm(currentUser, 'users')) { %>
                  <a href="/admin/users"><%- icon('users', 16) %> Utilisateurs</a>
                <% } %>
                <% if (APP.hasPerm(currentUser, 'finance')) { %>
                  <a href="/admin/commissions"><%- icon('cash', 16) %> Commissions</a>
                <% } %>
                <a href="/admin/account"><%- icon('settings', 16) %> Mon compte</a>
                <a href="/parent"><%- icon('eye', 16) %> Vue Parent</a>
                <a href="/coach"><%- icon('eye', 16) %> Vue Coach</a>
              <% } %>
              <% if (currentUser.role === 'coach') { %>
                <a href="/coach/profil"><%- icon('settings', 16) %> Mon profil</a>
              <% } %>
              <% if (currentUser.role === 'parent') { %>
                <a href="/parent/recherche"><%- icon('search', 16) %> Rechercher un coach</a>
              <% } %>
              <% if (currentUser.role !== 'commercial') { %>
                <a href="/parrainage"><%- icon('cash', 16) %> Parrainage &amp; gains</a>
              <% } %>
            </div>

            <div class="user-menu__divider"></div>
            <a href="/auth/logout" class="user-menu__logout"><%- icon('logout', 16) %> Déconnexion</a>
          </div>
        </div>
      <% } else { %>
        <a href="/auth/login" class="btn btn--ghost btn--sm">Connexion</a>
        <a href="/auth/register" class="btn btn--primary btn--sm">Créer un compte</a>
      <% } %>
    </nav>
  </div>
</header>
