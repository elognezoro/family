<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand brand--header">
      <img src="/images/logo.svg" alt="EduWeb" class="brand__logo" onerror="this.style.display='none'">
    </a>

    <button class="nav-toggle" id="navToggle" aria-label="Menu">
      <%- icon('menu', 24) %>
    </button>

    <nav class="site-nav" id="siteNav">
      <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>"><%= t('nav.home') %></a>
      <a href="/#ouvrages"><%= t('nav.books') %></a>
      <a href="/tarifs" class="<%= currentPath === '/tarifs' ? 'active' : '' %>"><%= t('nav.pricing') %></a>
      <a href="/a-propos" class="<%= currentPath === '/a-propos' ? 'active' : '' %>"><%= t('nav.about') %></a>

      <% if (currentUser) { %>
        <%
          function avatarInner() {
            if (currentUserPhoto) return '<img src="' + currentUserPhoto + '" alt="">';
            return (currentUser.name || '?').charAt(0);
          }
        %>
        <a href="/messages" class="nav-msg <%= currentPath.startsWith('/messages') ? 'active' : '' %>" aria-label="<%= t('menu.messages') %>">
          <%- icon('chat', 22) %>
          <span class="nav-msg__badge" id="navUnread" <%= unreadCount ? '' : 'hidden' %>><%= unreadCount > 99 ? '99+' : unreadCount %></span>
        </a>
        <div class="user-menu" id="userMenu">
          <button type="button" class="user-menu__trigger" id="userMenuBtn" aria-haspopup="true" aria-expanded="false" aria-label="Menu">
            <span class="nav-user__avatar"><%- avatarInner() %></span>
            <%- icon('chevronDown', 16) %>
          </button>
          <div class="user-menu__dropdown" id="userMenuDropdown" hidden>
            <div class="user-menu__head">
              <span class="nav-user__avatar nav-user__avatar--lg"><%- avatarInner() %></span>
              <div class="user-menu__id">
                <strong><%= currentUser.name %></strong>
                <span class="muted"><%= currentUser.email %></span>
                <span class="badge badge--soft"><%= currentUser.role %></span>
              </div>
            </div>

            <div class="user-menu__links">
              <a href="/<%= currentUser.role %>"><%- icon('dashboard', 16) %> <%= t('menu.space') %></a>
              <a href="/messages"><%- icon('chat', 16) %> <%= t('menu.messages') %><% if (unreadCount) { %> <span class="badge badge--no"><%= unreadCount > 99 ? '99+' : unreadCount %></span><% } %></a>
              <a href="/guides"><%- icon('book', 16) %> <%= currentUser.isSuperAdmin ? t('menu.guides') : t('menu.guide') %></a>

              <% if (currentUser.role === 'admin') { %>
                <% if (currentUser.isSuperAdmin) { %>
                  <a href="/admin/admins"><%- icon('shield', 16) %> <%= t('menu.admins') %></a>
                  <a href="/admin/settings"><%- icon('settings', 16) %> <%= t('menu.settings') %></a>
                <% } %>
                <% if (APP.hasPerm(currentUser, 'users')) { %>
                  <a href="/admin/users"><%- icon('users', 16) %> <%= t('menu.users') %></a>
                <% } %>
                <% if (APP.hasPerm(currentUser, 'finance')) { %>
                  <a href="/admin/commissions"><%- icon('cash', 16) %> Commissions</a>
                <% } %>
                <a href="/admin/account"><%- icon('settings', 16) %> <%= t('menu.account') %></a>
                <a href="/parent"><%- icon('eye', 16) %> <%= t('menu.viewParent') %></a>
                <a href="/coach"><%- icon('eye', 16) %> <%= t('menu.viewCoach') %></a>
              <% } %>
              <% if (currentUser.role === 'coach') { %>
                <a href="/coach/profil"><%- icon('settings', 16) %> <%= t('menu.profile') %></a>
              <% } %>
              <% if (currentUser.role === 'parent') { %>
                <a href="/parent/recherche"><%- icon('search', 16) %> <%= t('menu.searchCoach') %></a>
              <% } %>
              <% if (currentUser.role !== 'commercial') { %>
                <a href="/parrainage"><%- icon('cash', 16) %> <%= t('menu.referral') %></a>
              <% } %>
            </div>

            <div class="user-menu__divider"></div>
            <a href="/auth/logout" class="user-menu__logout"><%- icon('logout', 16) %> <%= t('menu.logout') %></a>
          </div>
        </div>
      <% } else { %>
        <a href="/auth/login" class="btn btn--ghost btn--sm"><%= t('nav.login') %></a>
        <a href="/auth/register" class="btn btn--primary btn--sm"><%= t('nav.register') %></a>
      <% } %>
    </nav>
  </div>
</header>
