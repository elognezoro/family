<footer class="site-footer">
  <div class="container site-footer__grid">
    <div class="site-footer__brand">
      <div class="brand brand--footer">
        <img src="/images/logo.svg" alt="EduWeb" class="brand__logo" onerror="this.style.display='none'">
      </div>
      <p class="site-footer__slogan"><%= APP.slogan %></p>
    </div>

    <div class="site-footer__col">
      <h4>Espaces</h4>
      <a href="/auth/register?role=parent">Espace Parent</a>
      <a href="/auth/register?role=coach">Espace Coach</a>
      <a href="/parent/recherche">Carte des coachs</a>
      <a href="/auth/register">Créer un compte</a>
    </div>

    <div class="site-footer__col">
      <h4>Plateforme</h4>
      <a href="/">À propos</a>
      <a href="/">Comment ça marche</a>
      <a href="/parent">Exprimer un besoin</a>
      <a href="/tarifs">Tarifs</a>
      <a href="/#ouvrages">Nos ouvrages</a>
      <a href="/auth/register?role=coach">Devenir coach</a>
    </div>

    <div class="site-footer__col">
      <h4>Contact</h4>
      <p><a href="mailto:<%= APP.contact.email %>"><%- icon('mail', 16) %> <%= APP.contact.email %></a></p>
      <p><a href="https://wa.me/<%= APP.contact.whatsapp %>" target="_blank" rel="noopener" class="wa-link">
