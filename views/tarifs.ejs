<section class="tarifs-hero">
  <div class="container">
    <span class="hero__badge">Tarification transparente</span>
    <h1 class="tarifs-hero__title">Nos tarifs</h1>
    <p class="tarifs-hero__sub">
      Chaque coach fixe librement son <strong>tarif horaire</strong>, au-dessus d'un minimum.
      La facture mensuelle dépend d'un engagement horaire minimum. Affichage en FCFA
      (1 € = <%= APP.EUR_RATE %> FCFA).
    </p>
  </div>
</section>

<section class="container section">
  <div class="pricing">
    <!-- Préscolaire / Maternelle -->
    <div class="pricing-card">
      <h3 class="pricing-card__title">Préscolaire / Maternelle</h3>
      <div class="pricing-card__price">
        <strong>dès <%= APP.formatFCFA(APP.pricing.minHoraire.prescolaire) %></strong>
        <span class="pricing-card__unit">/ heure (minimum)</span>
      </div>
      <div class="pricing-card__eur">Engagement : <%= APP.pricing.engagementMensuel.prescolaire %> h / mois minimum</div>
      <p class="pricing-card__desc">Facture mensuelle = tarif horaire × <%= APP.pricing.engagementMensuel.prescolaire %> h.
        Soit dès <strong><%= APP.formatFCFA(APP.factureMensuelle(APP.pricing.minHoraire.prescolaire, 'prescolaire')) %>/mois</strong>.</p>
      <ul class="pricing-card__list">
        <li><%- icon('check', 16) %> Coachs vérifiés et certifiés</li>
        <li><%- icon('check', 16) %> Suivi pédagogique inclus</li>
        <li><%- icon('check', 16) %> Paiement sécurisé Mobile Money</li>
      </ul>
      <a href="/auth/register?role=parent" class="btn btn--ghost btn--block">Commencer</a>
    </div>

    <!-- Primaire -->
    <div class="pricing-card pricing-card--featured">
      <span class="pricing-card__flag">Le plus choisi</span>
      <h3 class="pricing-card__title">Primaire</h3>
      <div class="pricing-card__price">
        <strong>dès <%= APP.formatFCFA(APP.pricing.minHoraire.primaire) %></strong>
        <span class="pricing-card__unit">/ heure (minimum)</span>
      </div>
      <div class="pricing-card__eur">Engagement : <%= APP.pricing.engagementMensuel.primaire %> h / mois minimum</div>
      <p class="pricing-card__desc">Facture mensuelle = tarif horaire × <%= APP.pricing.engagementMensuel.primaire %> h.
        Soit dès <strong><%= APP.formatFCFA(APP.factureMensuelle(APP.pricing.minHoraire.primaire, 'primaire')) %>/mois</strong>.</p>
      <ul class="pricing-card__list">
        <li><%- icon('check', 16) %> Coachs vérifiés et certifiés</li>
        <li><%- icon('check', 16) %> Suivi pédagogique inclus</li>
        <li><%- icon('check', 16) %> Paiement sécurisé Mobile Money</li>
      </ul>
      <a href="/auth/register?role=parent" class="btn btn--primary btn--block">Commencer</a>
    </div>

    <!-- Secondaire -->
    <div class="pricing-card">
      <h3 class="pricing-card__title">Secondaire</h3>
      <div class="pricing-card__price">
        <strong>dès <%= APP.formatFCFA(APP.pricing.minHoraire.secondaire) %></strong>
        <span class="pricing-card__unit">/ heure (minimum)</span>
      </div>
      <div class="pricing-card__eur">Engagement : <%= APP.pricing.engagementMensuel.secondaire %> h / mois (2 séances de 2 h/sem)</div>
      <p class="pricing-card__desc">Facture mensuelle = tarif horaire × <%= APP.pricing.engagementMensuel.secondaire %> h.
        Soit dès <strong><%= APP.formatFCFA(APP.factureMensuelle(APP.pricing.minHoraire.secondaire, 'secondaire1')) %>/mois</strong> par discipline.</p>
      <ul class="pricing-card__list">
        <li><%- icon('check', 16) %> Tarif par discipline</li>
        <li><%- icon('check', 16) %> Présentiel, visio ou hybride</li>
        <li><%- icon('check', 16) %> Paiement sécurisé Mobile Money</li>
      </ul>
      <a href="/auth/register?role=parent" class="btn btn--ghost btn--block">Commencer</a>
    </div>
  </div>

  <div class="tarifs-notes">
    <div class="info-banner"><%- icon('cash', 16) %> Le tarif est <strong>fixé par chaque coach</strong> (visible sur sa fiche), au-dessus du minimum indiqué. La <strong>facture mensuelle</strong> est calculée sur l'<strong>engagement horaire minimum</strong> du cycle. Le coach perçoit <strong>80 %</strong> du montant.</div>
    <p class="muted">Modes : <strong>présentiel</strong> (coach à proximité), <strong>visio</strong> (à distance) ou <strong>hybride</strong>. Des <strong>codes promo</strong> peuvent s'appliquer lors du paiement.</p>
  </div>
</section>

<section class="cta-band">
  <div class="container cta-band__inner">
    <h2>Prêt à commencer ?</h2>
    <p>Créez votre compte gratuitement et trouvez le coach idéal pour vos enfants.</p>
    <div class="cta-band__actions">
      <a href="/auth/register" class="btn btn--amber btn--lg">Créer un compte gratuit</a>
      <a href="/parent/recherche" class="btn btn--glass btn--lg">Explorer la carte</a>
    </div>
  </div>
</section>
