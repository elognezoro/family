<%
  var selNiveaux = profile.niveaux.map(function(n){ return n.niveauId; });
  var selModes = profile.modes.map(function(m){ return m.mode; });
  var discMap = {}; profile.disciplines.forEach(function(d){ discMap[d.disciplineId] = d.tarifMensuel; });
%>
<section class="container space coach-space">
  <div class="coach-layout">

    <%- include('../partials/coach-sidebar', { page: 'profil' }) %>

    <!-- ── Configuration du profil ── -->
    <div class="coach-main">

      <div class="profil-head">
        <div>
          <h1 class="space__title"><%- icon('settings', 24) %> <%= t('menu.profile') %></h1>
          <p class="space__sub"><%= t('cprofil.sub') %></p>
        </div>
        <a href="/coach" class="btn btn--ghost btn--sm">← <%= t('cdash.dashboard') %></a>
      </div>

      <!-- 1. Identité -->
      <section class="panel" id="identite">
        <div class="panel__head"><h2><span class="num">1</span> <%= t('csec.identity') %></h2></div>
        <form action="/coach/identite" method="POST" class="form" data-coach-form>
          <div class="field">
            <label><%= t('cprofil.country') %></label>
            <%- include('../partials/country-select', { zoneId: 'zone-coach', values: { pays: profile.pays } }) %>
          </div>
          <div class="form-row">
            <div class="field">
              <label><%= t('auth.nom') %></label>
              <input type="text" name="nom" value="<%= nameParts.nom %>" required data-uppercase placeholder="KOUASSI">
            </div>
            <div class="field">
              <label><%= t('auth.prenom') %></label>
              <input type="text" name="prenom" value="<%= nameParts.prenom %>" data-capitalize placeholder="Awa Marie">
            </div>
          </div>
          <div class="form-row">
            <div class="field">
              <label><%= t('auth.gender') %></label>
              <div class="radio-pills">
                <label class="radio-pill"><input type="radio" name="gender" value="Femme" <%= profile.user.gender==='Femme'?'checked':'' %>><span><%= t('auth.female') %></span></label>
                <label class="radio-pill"><input type="radio" name="gender" value="Homme" <%= profile.user.gender==='Homme'?'checked':'' %>><span><%= t('auth.male') %></span></label>
              </div>
            </div>
            <div class="field">
              <label><%= t('cprofil.phone') %></label>
              <input type="tel" name="phone" id="coachPhone" data-phone-indicatif value="<%= profile.user.phone || '' %>" placeholder="+225 …">
            </div>
          </div>
          <button class="btn btn--primary"><%= t('common.save') %></button>
        </form>
      </section>

      <!-- 2. Zone d'intervention -->
      <section class="panel" id="zone">
        <div class="panel__head"><h2><span class="num">2</span> <%= t('csec.zone') %></h2></div>
        <form action="/coach/zone" method="POST" class="form" data-coach-form>
          <p class="muted hint"><%- t('cprofil.zoneHint') %></p>
          <%- include('../partials/zone-cascade', { zoneId: 'zone-coach', includeHiddenPays: true, values: { pays: profile.pays, region: profile.region, commune: profile.commune } }) %>
          <div class="form-row">
            <div class="field"><label><%= t('pdash.neighborhood') %></label><input type="text" name="quartier" value="<%= profile.quartier || '' %>" placeholder="Ex: Angré"></div>
            <div class="field"><label><%= t('cprofil.address') %></label><input type="text" name="adresse" value="<%= profile.adresse || '' %>" placeholder="Repère / rue"></div>
          </div>
          <div class="form-row">
            <div class="field"><label><%= t('cprofil.gpsLat') %></label><input type="text" name="gpsLat" id="gpsLat" value="<%= profile.gpsLat || '' %>" placeholder="5.345"></div>
            <div class="field"><label><%= t('cprofil.gpsLng') %></label><input type="text" name="gpsLng" id="gpsLng" value="<%= profile.gpsLng || '' %>" placeholder="-4.001"></div>
          </div>
          <div class="gps-actions">
            <button type="button" class="btn btn--ghost btn--sm" id="gpsLocateBtn"><%- icon('pin', 16) %> <%= t('cprofil.locate') %></button>
            <a href="#" class="btn btn--ghost btn--sm" id="gpsMapLink" target="_blank" rel="noopener" hidden><%- icon('map', 16) %> <%= t('cprofil.seeMap') %></a>
            <span class="muted gps-hint" id="gpsHint"><%= t('cprofil.gpsHint') %></span>
          </div>
          <button class="btn btn--primary mt"><%= t('common.save') %></button>
        </form>
      </section>

      <!-- 3. Compétences -->
      <section class="panel" id="competences">
        <div class="panel__head"><h2><span class="num">3</span> <%= t('cprofil.skillsTitle') %></h2></div>
        <form action="/coach/competences" method="POST" class="form" data-coach-form>
          <label class="field-label"><%= t('cprofil.levelsTaught') %></label>
          <% niveauxData.niveauxGrouped().forEach(function(grp){ %>
            <div class="acc acc--static">
              <button type="button" class="acc__head"><%= grp.label %> <%- icon('chevronDown', 16) %></button>
              <div class="acc__body">
                <div class="check-pills">
                  <% grp.niveaux.forEach(function(n){ %>
                    <label class="check-pill"><input type="checkbox" name="niveaux" value="<%= n.id %>" <%= selNiveaux.includes(n.id)?'checked':'' %>><span><%= n.label %></span></label>
                  <% }) %>
                </div>
              </div>
            </div>
          <% }) %>

          <label class="field-label mt"><%= t('cprofil.teachingModes') %></label>
          <div class="check-pills">
            <% APP.modes.forEach(function(m){ %>
              <label class="check-pill"><input type="checkbox" name="modes" value="<%= m.id %>" <%= selModes.includes(m.id)?'checked':'' %>><span><%= m.id==='hybride' ? t('mode.hybride') : t('mode.' + m.id) %></span></label>
            <% }) %>
          </div>
          <button class="btn btn--primary mt"><%= t('common.save') %></button>
        </form>
      </section>

      <!-- 4. Disciplines & tarifs -->
      <section class="panel" id="disciplines">
        <div class="panel__head"><h2><span class="num">4</span> <%= t('csec.disciplines') %></h2></div>
        <% var per = currency.perEUR; var sym = currency.symbol; %>
        <div class="info-banner"><%- icon('cash', 16) %> <%- t('cprofil.ratesBanner').replace('{sym}', sym) %></div>
        <form action="/coach/disciplines" method="POST" class="form" data-coach-form>
          <% disciplinesData.disciplinesGrouped().forEach(function(grp){
               var isSingle = (grp.cycle === 'prescolaire' || grp.cycle === 'primaire');
               var eng = APP.engagementMensuel(grp.cycle);
               var min = APP.minHoraire(grp.cycle);          // FCFA
               var minLocal = APP.localFromFcfa(min, per);
               var cycleTarif = min;
               if (isSingle) {
                 var allItems = grp.domaines.reduce(function(a, dm){ return a.concat(dm.items); }, []);
                 var found = allItems.find(function(d){ return discMap.hasOwnProperty(d.id); });
                 if (found) cycleTarif = discMap[found.id];
               }
               function estim(tarif){ var f = APP.factureMensuelle(tarif, grp.cycle); return '≈ ' + APP.money(f) + t('cdash.perMonth') + ' (' + eng + 'h) · ' + t('cprofil.you') + ' ' + APP.money(APP.partCoach(f)); }
          %>
            <div class="acc acc--static">
              <button type="button" class="acc__head"><%= grp.cycleLabel %> <%- icon('chevronDown', 16) %></button>
              <div class="acc__body">
                <% if (isSingle) { %>
                  <div class="cycle-tarif">
                    <label class="field-label"><%= t('cprofil.cycleRate') %> <span class="muted"><%= t('cprofil.free') %></span></label>
                    <div class="disc-row__tarif">
                      <input type="number" name="tarif_cycle_<%= grp.cycle %>" value="<%= APP.localFromFcfa(cycleTarif, per) %>" min="0" step="any" class="input-sm" data-tarif data-engagement="<%= eng %>" data-pereur="<%= per %>">
                      <span class="muted"><%= sym %> / h</span>
                      <span class="rate-eur" data-rate-eur>≈ <%= APP.formatEUR(cycleTarif) %></span>
                      <span class="tarif-estimate" data-estimate><%= estim(cycleTarif) %></span>
                    </div>
                  </div>
                <% } %>
                <% grp.domaines.forEach(function(dom){ %>
                  <div class="acc__group"><span class="acc__group-label"><%= dom.nom %></span>
                    <% if (isSingle) { %>
                      <div class="check-pills">
                        <% dom.items.forEach(function(d){ var sel = discMap.hasOwnProperty(d.id); %>
                          <label class="check-pill"><input type="checkbox" name="discipline" value="<%= d.id %>" <%= sel?'checked':'' %>><span><%= d.matiere %></span></label>
                        <% }) %>
                      </div>
                    <% } else { %>
                      <% dom.items.forEach(function(d){ var sel = discMap.hasOwnProperty(d.id); var cur = sel ? discMap[d.id] : min; %>
                        <div class="disc-row">
                          <label class="check-pill"><input type="checkbox" name="discipline" value="<%= d.id %>" <%= sel?'checked':'' %>><span><%= d.matiere %></span></label>
                          <div class="disc-row__tarif">
                            <input type="number" name="tarif_<%= d.id %>" value="<%= APP.localFromFcfa(cur, per) %>" min="0" step="any" class="input-sm" data-tarif data-engagement="<%= eng %>" data-pereur="<%= per %>">
                            <span class="muted"><%= sym %> / h</span>
                            <span class="rate-eur" data-rate-eur>≈ <%= APP.formatEUR(cur) %></span>
                            <span class="tarif-estimate" data-estimate><%= estim(cur) %></span>
                          </div>
                        </div>
                      <% }) %>
                    <% } %>
                  </div>
                <% }) %>
              </div>
            </div>
          <% }) %>
          <button class="btn btn--primary mt"><%= t('common.save') %></button>
        </form>
      </section>

      <!-- 5. Documents -->
      <section class="panel" id="documents">
        <div class="panel__head"><h2><span class="num">5</span> <%= t('csec.documents') %></h2></div>
        <%
          var docTypes = [
            { key: 'diplome',    label: t('cprofil.doc.diplome'),    hint: t('cprofil.doc.diplomeHint') },
            { key: 'cni',        label: t('cprofil.doc.cni'),        hint: t('cprofil.doc.cniHint') },
            { key: 'cv',         label: t('cprofil.doc.cv'),         hint: t('cprofil.doc.cvHint') },
            { key: 'certificat', label: t('cprofil.doc.certificat'), hint: t('cprofil.doc.certificatHint') }
          ];
          var providedTypes = {}; profile.documents.forEach(function(d){ providedTypes[d.type] = true; });
        %>
        <div class="info-banner"><%- icon('doc', 16) %> <%- t('cprofil.docsBanner') %></div>

        <p class="field-label"><%= t('cprofil.docsToProvide') %> <span class="muted"><%= t('cprofil.docsClickHint') %></span></p>
        <ul class="doc-req">
          <% docTypes.forEach(function(dt){ var ok = providedTypes[dt.key]; %>
            <li class="doc-req__item <%= ok ? 'is-ok' : '' %>">
              <form action="/coach/documents" method="POST" enctype="multipart/form-data" class="doc-req__form">
                <input type="hidden" name="type" value="<%= dt.key %>">
                <label class="doc-req__pick">
                  <input type="file" name="document" accept=".pdf,.jpg,.jpeg,.png,.webp,.doc,.docx" hidden onchange="if(this.files.length){this.form.submit();}">
                  <span class="doc-req__icon"><%- icon(ok ? 'check' : 'doc', 16) %></span>
                  <span class="doc-req__label"><strong><%= dt.label %></strong><span class="muted"><%= dt.hint %></span></span>
                  <span class="doc-req__action"><%- icon('upload', 14) %> <%= ok ? t('cdash.add') : t('cprofil.import') %></span>
                  <span class="badge <%= ok ? 'badge--ok' : 'badge--pending' %>"><%= ok ? t('cprofil.provided') : t('cprofil.toProvide') %></span>
                </label>
              </form>
            </li>
          <% }) %>
        </ul>
        <p class="muted hint"><%- icon('clip', 14) %> <%= t('cprofil.docsFormats') %></p>

        <% if (profile.documents.length) { %>
          <div class="doc-list">
            <% profile.documents.forEach(function(doc){ %>
              <div class="doc-item">
                <%- icon('doc', 18) %>
                <div class="doc-item__info">
                  <a href="<%= doc.url %>" target="_blank"><%= doc.filename %></a>
                  <span class="muted"><%= doc.type %></span>
                </div>
                <form action="/coach/documents/<%= doc.id %>/delete" method="POST"><button class="icon-btn icon-btn--danger" title="<%= t('common.delete') %>"><%- icon('trash', 14) %></button></form>
              </div>
            <% }) %>
          </div>
        <% } %>
      </section>

      <!-- 6. Présentation -->
      <section class="panel" id="presentation">
        <div class="panel__head"><h2><span class="num">6</span> <%= t('csec.presentation') %></h2></div>
        <div class="info-banner"><%- icon('edit', 16) %> <%- t('cprofil.presBanner') %></div>
        <form action="/coach/presentation" method="POST" class="form" data-coach-form>
          <div class="field">
            <div class="field-head">
              <label><%= t('cprofil.bio') %></label>
              <button type="button" class="btn btn--ghost btn--sm" data-regen="presentation"><%- icon('settings', 14) %> <%= t('cprofil.regen') %></button>
            </div>
            <textarea name="presentation" id="presentationText" rows="5" placeholder="<%= t('cprofil.bioPh') %>"><%= profile.presentation || suggestions.presentation %></textarea>
          </div>
          <div class="field">
            <div class="field-head">
              <label><%= t('cprofil.experience') %></label>
              <button type="button" class="btn btn--ghost btn--sm" data-regen="experience"><%- icon('settings', 14) %> <%= t('cprofil.regen') %></button>
            </div>
            <textarea name="experience" id="experienceText" rows="4" placeholder="<%= t('cprofil.expPh') %>"><%= profile.experience || suggestions.experience %></textarea>
          </div>
          <button class="btn btn--primary"><%= t('common.save') %></button>
        </form>
      </section>

    </div>
  </div>
</section>

<script>
  window.EDUWEB_EUR_RATE = <%= APP.EUR_RATE %>;
  window.EDUWEB_SUGGESTIONS = <%- JSON.stringify(suggestions) %>;
</script>
