<section class="container space">
  <div class="space__head">
    <div>
      <h1 class="space__title"><%= t('pdash.greeting') %>, <%= currentUser.name %></h1>
      <p class="space__sub"><%= t('pdash.welcome') %></p>
    </div>
  </div>

  <!-- KPIs -->
  <div class="kpi-grid">
    <div class="kpi"><div class="kpi__icon kpi__icon--green"><%- icon('users', 22) %></div><div><div class="kpi__value"><%= stats.learners %></div><div class="kpi__label"><%= t('pdash.kpi.learners') %></div></div></div>
    <div class="kpi"><div class="kpi__icon kpi__icon--amber"><%- icon('book', 22) %></div><div><div class="kpi__value"><%= stats.needs %></div><div class="kpi__label"><%= t('pdash.kpi.needs') %></div></div></div>
    <div class="kpi"><div class="kpi__icon kpi__icon--green"><%- icon('graduation', 22) %></div><div><div class="kpi__value"><%= stats.missions %></div><div class="kpi__label"><%= t('pdash.kpi.missions') %></div></div></div>
    <div class="kpi"><div class="kpi__icon kpi__icon--amber"><%- icon('cash', 22) %></div><div><div class="kpi__value"><%= APP.formatFCFA(stats.totalPaid) %></div><div class="kpi__label"><%= t('pdash.kpi.totalPaid') %> · ≈ <%= APP.formatEUR(stats.totalPaid) %></div></div></div>
  </div>

  <%- include('../partials/dash-tools') %>

  <!-- Onglets -->
  <div class="tabs" data-tabs>
    <div class="tabs__nav">
      <button class="tab" data-tab="famille"><%- icon('users', 18) %> <%= t('pdash.tab.family') %></button>
      <button class="tab" data-tab="besoins"><%- icon('book', 18) %> <%= t('pdash.kpi.needs') %></button>
      <button class="tab" data-tab="recherche-tab"><%- icon('search', 18) %> <%= t('pdash.tab.coaches') %></button>
      <button class="tab" data-tab="reservations"><%- icon('graduation', 18) %> <%= t('pdash.tab.bookings') %></button>
      <button class="tab" data-tab="paiements"><%- icon('cash', 18) %> <%= t('pdash.tab.payments') %></button>
    </div>

    <!-- ── Ma Famille ── -->
    <div class="tab-panel" id="famille">
      <div class="panel">
        <div class="panel__head">
          <h2><%- icon('users', 20) %> <%= family.label %></h2>
          <button class="btn btn--primary btn--sm" data-open-modal="modal-learner"><%- icon('plus', 16) %> <%= t('pdash.addLearner') %></button>
        </div>

        <% if (family.learners.length === 0) { %>
          <div class="empty"><%- icon('users', 40) %><p><%= t('pdash.noLearner') %></p></div>
        <% } else { %>
          <div class="learner-grid">
            <% family.learners.forEach(function(l, i){ %>
              <div class="learner-card">
                <div class="learner-card__top">
                  <div class="learner-card__avatar <%= l.sexe === 'F' ? 'is-f' : 'is-m' %>"><%= l.sexe || '?' %></div>
                  <div>
                    <div class="learner-card__title"><%= t('pdash.learner') %> #<%= i + 1 %></div>
                    <div class="learner-card__meta">
                      <%= l.age ? l.age + ' ' + t('pdash.years') : t('pdash.ageUnknown') %> ·
                      <%= l.niveau ? niveauxData.niveauLabel(l.niveau) : (l.cycle ? niveauxData.cycleLabel(l.cycle) : t('pdash.levelUnknown')) %>
                      <%= l.serie ? ' · ' + t('pdash.series') + ' ' + l.serie : '' %>
                    </div>
                  </div>
                  <form action="/parent/learner/<%= l.id %>/delete" method="POST" class="learner-card__del" onsubmit="return confirm('<%= t('pdash.confirmDeleteLearner') %>')">
                    <button class="icon-btn icon-btn--danger" title="<%= t('common.delete') %>"><%- icon('trash', 16) %></button>
                  </form>
                </div>
                <div class="learner-card__loc">
                  <%- icon('pin', 14) %>
                  <span><%= countryName(l.pays) %><%= l.commune ? ' · ' + l.commune : '' %><%= l.quartier ? ' · ' + l.quartier : '' %></span>
                </div>
                <div class="learner-card__needs">
                  <% if (l.needs.length === 0) { %>
                    <span class="muted"><%= t('pdash.noNeed') %></span>
                  <% } else { %>
                    <% l.needs.forEach(function(n){ %>
                      <span class="tag"><%= disciplinesData.disciplineLabel(n.disciplineId) %></span>
                    <% }) %>
                  <% } %>
                </div>
                <div class="learner-card__actions">
                  <button type="button" class="btn btn--ghost btn--sm" data-goto-tab="besoins" data-scroll-to="#besoin-<%= l.id %>"><%- icon('edit', 14) %> <%= t('pdash.editNeeds') %></button>
                  <% if (l.needs.length) { %>
                    <a href="/parent/recherche?learner=<%= l.id %>" class="btn btn--primary btn--sm"><%- icon('search', 14) %> <%= t('menu.searchCoach') %></a>
                  <% } else { %>
                    <button type="button" class="btn btn--primary btn--sm" data-goto-tab="besoins" data-scroll-to="#besoin-<%= l.id %>"><%- icon('plus', 14) %> <%= t('pdash.addNeed') %></button>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>

    <!-- ── Besoins ── -->
    <div class="tab-panel" id="besoins">
      <div class="panel">
        <div class="panel__head"><h2><%- icon('book', 20) %> <%= t('pdash.declareNeeds') %></h2></div>
        <% if (family.learners.length === 0) { %>
          <div class="empty"><p><%= t('pdash.addLearnerFirst') %></p></div>
        <% } else { %>
          <% family.learners.forEach(function(l, i){ %>
            <div class="need-block" id="besoin-<%= l.id %>">
              <div class="need-block__head">
                <h3 class="need-block__title"><%= t('pdash.learner') %> #<%= i + 1 %> — <%= l.niveau ? niveauxData.niveauLabel(l.niveau) : (l.cycle ? niveauxData.cycleLabel(l.cycle) : t('pdash.levelUnknown')) %></h3>
                <% if (l.needs.length) { %>
                  <a href="/parent/recherche?learner=<%= l.id %>" class="btn btn--ghost btn--sm"><%- icon('search', 14) %> <%= t('menu.searchCoach') %></a>
                <% } %>
              </div>

              <% if (l.needs.length) { %>
                <div class="need-list">
                  <% l.needs.forEach(function(n){ %>
                    <div class="need-item">
                      <span class="tag tag--lg"><%= disciplinesData.disciplineLabel(n.disciplineId) %></span>
                      <form action="/parent/need/<%= n.id %>/update" method="POST" class="need-edit">
                        <select name="mode" class="select-sm">
                          <option value="presentiel" <%= n.mode==='presentiel'?'selected':'' %>><%= t('mode.presentiel') %></option>
                          <option value="visio" <%= n.mode==='visio'?'selected':'' %>><%= t('mode.visio') %></option>
                          <option value="hybride" <%= n.mode==='hybride'?'selected':'' %>><%= t('mode.hybride') %></option>
                        </select>
                        <input type="number" name="heuresSemaine" value="<%= n.heuresSemaine %>" min="1" max="20" class="input-sm" title="<%= t('pdash.hPerWeek') %>">
                        <span class="muted"><%= t('pdash.hPerWeek') %></span>
                        <button type="submit" class="btn btn--ghost btn--sm" title="<%= t('common.save') %>"><%- icon('check', 14) %> <%= t('common.edit') %></button>
                      </form>
                      <form action="/parent/need/<%= n.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Supprimer ce besoin ?')"><button class="icon-btn icon-btn--danger" title="<%= t('common.delete') %>"><%- icon('trash', 14) %></button></form>
                    </div>
                  <% }) %>
                </div>
              <% } %>

              <form action="/parent/learner/<%= l.id %>/need" method="POST" class="need-form">
                <div class="disc-picker" data-discipline-picker data-cycle="<%= l.cycle || '' %>">
                  <button type="button" class="btn btn--ghost btn--sm disc-picker__toggle"><%- icon('plus', 14) %> <%= t('pdash.chooseDisciplines') %></button>
                  <div class="disc-picker__box" hidden>
                    <% disciplinesData.disciplinesGrouped().forEach(function(grp){ %>
                      <div class="acc" data-cycle="<%= grp.cycle %>">
                        <button type="button" class="acc__head"><%= grp.cycleLabel %> <%- icon('chevronDown', 16) %></button>
                        <div class="acc__body">
                          <% grp.domaines.forEach(function(dom){ %>
                            <div class="acc__group"><span class="acc__group-label"><%= dom.nom %></span>
                              <div class="check-pills">
                                <% dom.items.forEach(function(d){ %>
                                  <label class="check-pill"><input type="checkbox" name="disciplineId" value="<%= d.id %>"><span><%= d.matiere %></span></label>
                                <% }) %>
                              </div>
                            </div>
                          <% }) %>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                </div>
                <div class="need-form__opts">
                  <select name="mode" class="select-sm">
                    <option value="presentiel"><%= t('mode.presentiel') %></option>
                    <option value="visio"><%= t('mode.visio') %></option>
                    <option value="hybride"><%= t('mode.hybride') %></option>
                  </select>
                  <input type="number" name="heuresSemaine" value="2" min="1" max="20" class="input-sm" title="<%= t('pdash.hPerWeek') %>"> <span class="muted"><%= t('pdash.hPerWeek') %></span>
                  <button type="submit" class="btn btn--primary btn--sm"><%= t('common.save') %></button>
                </div>
              </form>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <!-- ── Coachs ── -->
    <div class="tab-panel" id="recherche-tab">
      <div class="panel">
        <div class="panel__head"><h2><%- icon('search', 20) %> <%= t('menu.searchCoach') %></h2></div>
        <p><%= t('pdash.searchDesc') %></p>
        <a href="/parent/recherche" class="btn btn--primary"><%- icon('map', 18) %> <%= t('pdash.openSearch') %></a>
      </div>
    </div>

    <!-- ── Réservations ── -->
    <div class="tab-panel" id="reservations">
      <div class="panel">
        <div class="panel__head"><h2><%- icon('graduation', 20) %> <%= t('pdash.myBookings') %></h2><a href="/parent/recherche" class="btn btn--primary btn--sm"><%- icon('search', 14) %> <%= t('pdash.bookCoach') %></a></div>
        <% if (!missions.length) { %>
          <div class="empty"><%- icon('graduation', 40) %><p><%= t('pdash.noBooking') %></p></div>
        <% } else { %>
          <div class="table-wrap">
            <table class="table">
              <thead><tr><th><%= t('common.date') %></th><th><%= t('th.coach') %></th><th><%= t('th.discipline') %></th><th><%= t('th.mode') %></th><th><%= t('th.engagement') %></th><th><%= t('th.amountMonth') %></th><th><%= t('th.status') %></th><th><%= t('th.review') %></th></tr></thead>
              <tbody>
                <% missions.forEach(function(m){
                     var stCls = m.statut==='active'?'badge--ok':(m.statut==='refuse'?'badge--no':'badge--pending');
                     var reviewed = reviewedMissionIds.indexOf(m.id) !== -1; %>
                  <tr>
                    <td class="muted"><%= new Date(m.createdAt).toLocaleDateString('fr-FR') %></td>
                    <td><strong><%= m.coach ? m.coach.name : '—' %></strong></td>
                    <td><%= m.disciplineId ? disciplinesData.disciplineLabel(m.disciplineId) : '—' %></td>
                    <td><%= m.mode ? (m.mode==='hybride' ? t('mode.hybrideShort') : t('mode.' + m.mode)) : '—' %></td>
                    <td><%= m.heuresMois ? m.heuresMois + ' ' + t('pdash.hPerMonth') : '—' %></td>
                    <td><strong><%= APP.formatFCFA(m.montant || 0) %></strong><br><span class="muted">≈ <%= APP.formatEUR(m.montant || 0) %></span></td>
                    <td><span class="badge <%= stCls %>"><%= t('status.' + m.statut) %></span></td>
                    <td>
                      <% if (m.statut === 'active' && !reviewed) { %>
                        <button class="btn btn--ghost btn--sm" data-open-modal="avis-<%= m.id %>"><%- icon('star', 13) %> <%= t('pdash.rate') %></button>
                      <% } else if (reviewed) { %>
                        <span class="badge badge--soft"><%- icon('check', 12) %> <%= t('pdash.rated') %></span>
                      <% } else { %><span class="muted">—</span><% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Modals d'évaluation -->
    <% missions.forEach(function(m){ if (m.statut === 'active' && reviewedMissionIds.indexOf(m.id) === -1) { %>
      <div class="modal" id="avis-<%= m.id %>" hidden>
        <div class="modal__backdrop" data-close-modal></div>
        <div class="modal__dialog">
          <div class="modal__head"><h3><%= t('pdash.rate') %> <%= m.coach ? m.coach.name : '' %></h3><button class="modal__close" data-close-modal>&times;</button></div>
          <form action="/parent/avis" method="POST" class="form modal__body">
            <input type="hidden" name="missionId" value="<%= m.id %>">
            <div class="field">
              <label><%= t('pdash.yourRating') %></label>
              <div class="star-input">
                <% for (var s = 5; s >= 1; s--) { %>
                  <input type="radio" name="note" id="star-<%= m.id %>-<%= s %>" value="<%= s %>" <%= s===5?'required':'' %>>
                  <label for="star-<%= m.id %>-<%= s %>" title="<%= s %>">★</label>
                <% } %>
              </div>
            </div>
            <div class="field">
              <label><%= t('pdash.commentOptional') %></label>
              <textarea name="commentaire" rows="3" maxlength="500" placeholder="<%= t('pdash.shareExperience') %>"></textarea>
            </div>
            <button type="submit" class="btn btn--primary btn--block"><%= t('pdash.sendReview') %></button>
          </form>
        </div>
      </div>
    <% } }) %>

    <!-- ── Paiements ── -->
    <div class="tab-panel" id="paiements">
      <div class="panel">
        <div class="panel__head"><h2><%- icon('cash', 20) %> <%= t('pdash.payment') %></h2></div>
        <form action="/parent/payment" method="POST" class="pay-form" id="payForm">
          <div class="form-row">
            <div class="field">
              <label><%= t('pdash.grossAmount') %></label>
              <input type="number" name="brut" id="payBrut" value="60000" min="0" step="500" required>
            </div>
            <div class="field">
              <label><%= t('pdash.promoCode') %></label>
              <input type="text" name="promoCode" placeholder="EDU10, EDU25…" data-uppercase>
            </div>
          </div>
          <div class="field">
            <label><%= t('pdash.operator') %></label>
            <div class="op-pills">
              <% APP.operateurs.forEach(function(op, i){ %>
                <label class="op-pill"><input type="radio" name="operateur" value="<%= op.id %>" <%= i===0?'checked':'' %>><span style="--op:<%= op.color %>"><%= op.label %></span></label>
              <% }) %>
            </div>
          </div>
          <p class="pay-conv" id="payConv"></p>
          <button type="submit" class="btn btn--primary btn--lg"><%= t('pdash.pay') %></button>
        </form>

        <% if (payments.length) { %>
          <h3 class="mt"><%= t('pdash.history') %></h3>
          <div class="table-wrap">
            <table class="table">
              <thead><tr><th><%= t('common.date') %></th><th><%= t('th.gross') %></th><th><%= t('th.discount') %></th><th><%= t('th.net') %></th><th><%= t('th.operator') %></th><th><%= t('th.transaction') %></th></tr></thead>
              <tbody>
                <% payments.forEach(function(p){ %>
                  <tr>
                    <td><%= new Date(p.createdAt).toLocaleDateString('fr-FR') %></td>
                    <td><%= APP.formatFCFA(p.brut) %><br><span class="muted">≈ <%= APP.formatEUR(p.brut) %></span></td>
                    <td><%= p.pct ? ('-' + p.pct + '%') : '—' %></td>
                    <td><strong><%= APP.formatFCFA(p.net) %></strong><br><span class="muted">≈ <%= APP.formatEUR(p.net) %></span></td>
                    <td><%= p.operateur %></td>
                    <td class="muted"><%= p.transactionId %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>

<!-- Modal ajout apprenant -->
<div class="modal" id="modal-learner" hidden>
  <div class="modal__backdrop" data-close-modal></div>
  <div class="modal__dialog">
    <div class="modal__head">
      <h3><%= t('pdash.addLearner') %></h3>
      <button class="modal__close" data-close-modal>&times;</button>
    </div>
    <form action="/parent/learner" method="POST" class="form modal__body">
      <div class="info-banner"><%- icon('shield', 16) %> <%- t('pdash.minorProtection') %></div>
      <div class="form-row">
        <div class="field">
          <label><%= t('pdash.sex') %></label>
          <div class="radio-pills">
            <label class="radio-pill"><input type="radio" name="sexe" value="F"><span><%= t('pdash.girl') %></span></label>
            <label class="radio-pill"><input type="radio" name="sexe" value="M"><span><%= t('pdash.boy') %></span></label>
          </div>
        </div>
        <div class="field">
          <label><%= t('pdash.age') %></label>
          <input type="number" name="age" min="2" max="25" placeholder="Ex: 12">
        </div>
      </div>

      <%- include('../partials/geo-fields', { zoneId: 'zone-learner', values: {} }) %>

      <div class="field">
        <label><%= t('pdash.neighborhood') %></label>
        <input type="text" name="quartier" placeholder="Ex: Riviera 2">
      </div>

      <div class="form-row">
        <div class="field">
          <label><%= t('pdash.cycle') %></label>
          <select name="cycle" id="learnerCycle">
            <option value=""><%= t('pdash.choose') %></option>
            <% niveauxData.cycles.forEach(function(c){ %><option value="<%= c.id %>"><%= c.label %></option><% }) %>
          </select>
        </div>
        <div class="field">
          <label><%= t('pdash.level') %></label>
          <select name="niveau" id="learnerNiveau"><option value=""><%= t('pdash.chooseCycleFirst') %></option></select>
        </div>
        <div class="field" id="serieField" hidden>
          <label><%= t('pdash.series') %></label>
          <select name="serie" id="learnerSerie"><option value="">—</option></select>
        </div>
      </div>

      <button type="submit" class="btn btn--primary btn--block btn--lg"><%= t('pdash.addLearnerBtn') %></button>
    </form>
  </div>
</div>

<script>
  window.EDUWEB_NIVEAUX = <%- JSON.stringify(niveauxData.niveaux) %>;
  window.EDUWEB_EUR_RATE = <%= APP.EUR_RATE %>;
</script>
