<div class="auth-wrap">
  <a href="/" class="auth-back"><%- icon('home', 16) %> Accueil</a>
  <div class="auth-card">
    <div class="auth-logo">
      <div class="auth-logo__halo"></div>
      <img src="/images/logo.svg" alt="EduWeb" onerror="this.outerHTML='<div class=\'auth-logo__fallback\'>Edu<span>Web</span></div>'">
    </div>
    <h1 class="auth-title">Connexion</h1>
    <p class="auth-sub"><%= APP.slogan %></p>

    <form action="/auth/login" method="POST" class="form">
      <div class="field">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required placeholder="vous@exemple.ci">
      </div>
      <div class="field">
        <label for="password">Mot de passe</label>
        <input type="password" id="password" name="password" required placeholder="••••••••">
      </div>
      <label class="checkbox">
        <input type="checkbox" name="remember" value="1">
        <span>Me maintenir connecté (30 jours)</span>
      </label>

      <button type="submit" class="btn btn--primary btn--block btn--lg">Se connecter</button>
    </form>

    <details class="resend">
      <summary>Compte non activé ? Renvoyer le lien</summary>
      <form action="/auth/resend" method="POST" class="form resend__form">
        <div class="field">
          <input type="email" name="email" required placeholder="Votre email">
        </div>
        <button type="submit" class="btn btn--ghost btn--block">Renvoyer le lien d'activation</button>
      </form>
    </details>

    <p class="auth-foot">Pas de compte ? <a href="/auth/register">Créer un compte</a></p>
  </div>
</div>
