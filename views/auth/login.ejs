<div class="auth-wrap">
  <a href="/" class="auth-back"><%- icon('home', 16) %> <%= t('nav.home') %></a>
  <div class="auth-card">
    <div class="auth-logo">
      <div class="auth-logo__halo"></div>
      <img src="/images/logo.svg" alt="EduWeb" onerror="this.outerHTML='<div class=\'auth-logo__fallback\'>Edu<span>Web</span></div>'">
    </div>
    <h1 class="auth-title"><%= t('auth.title.login') %></h1>
    <p class="auth-sub"><%= t('home.slogan') %></p>

    <form action="/auth/login" method="POST" class="form">
      <div class="field">
        <label for="email"><%= t('auth.email') %></label>
        <input type="email" id="email" name="email" required placeholder="vous@exemple.ci">
      </div>
      <div class="field">
        <label for="password"><%= t('auth.password') %></label>
        <input type="password" id="password" name="password" required placeholder="••••••••">
      </div>
      <label class="checkbox">
        <input type="checkbox" name="remember" value="1">
        <span><%= t('auth.remember') %></span>
      </label>

      <button type="submit" class="btn btn--primary btn--block btn--lg"><%= t('auth.signin') %></button>
    </form>

    <details class="resend">
      <summary><%= t('auth.resendSummary') %></summary>
      <form action="/auth/resend" method="POST" class="form resend__form">
        <div class="field">
          <input type="email" name="email" required placeholder="<%= t('auth.yourEmail') %>">
        </div>
        <button type="submit" class="btn btn--ghost btn--block"><%= t('auth.resendBtn') %></button>
      </form>
    </details>

    <p class="auth-foot"><%= t('auth.noAccount') %> <a href="/auth/register"><%= t('auth.title.register') %></a></p>
  </div>
</div>
