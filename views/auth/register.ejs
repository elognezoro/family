<div class="auth-wrap">
  <a href="/" class="auth-back"><%- icon('home', 16) %> Accueil</a>
  <div class="auth-card">
    <div class="auth-logo">
      <div class="auth-logo__halo"></div>
      <img src="/images/logo.svg" alt="EduWeb" onerror="this.outerHTML='<div class=\'auth-logo__fallback\'>Edu<span>Web</span></div>'">
    </div>
    <h1 class="auth-title">Créer un compte</h1>
    <p class="auth-sub"><%= APP.slogan %></p>

    <form action="/auth/register" method="POST" class="form" id="registerForm">
      <div class="form-row">
        <div class="field">
          <label for="nom">NOM</label>
          <input type="text" id="nom" name="nom" required data-uppercase placeholder="KOUASSI">
        </div>
        <div class="field">
          <label for="prenom">Prénom(s)</label>
          <input type="text" id="prenom" name="prenom" required data-capitalize placeholder="Awa Marie">
        </div>
      </div>

      <div class="field">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required placeholder="vous@exemple.ci">
      </div>

      <div class="form-row">
        <div class="field">
          <label for="password">Mot de passe</label>
          <input type="password" id="password" name="password" required minlength="6" placeholder="6 caractères min.">
        </div>
        <div class="field">
          <label for="confirm">Confirmer</label>
          <input type="password" id="confirm" name="confirm" required minlength="6" placeholder="Répétez">
        </div>
      </div>

      <div class="field">
        <label>Genre</label>
        <div class="radio-pills">
          <label class="radio-pill"><input type="radio" name="gender" value="Femme"><span>Femme</span></label>
          <label class="radio-pill"><input type="radio" name="gender" value="Homme"><span>Homme</span></label>
        </div>
      </div>

      <div class="field">
        <label>Type de compte</label>
        <div class="role-pills">
          <label class="role-pill">
            <input type="radio" name="role" value="parent" checked>
            <div class="role-pill__body">
              <%- icon('users', 26) %>
              <strong>Parent</strong>
              <small>Je cherche un coach</small>
            </div>
          </label>
          <label class="role-pill">
            <input type="radio" name="role" value="coach">
            <div class="role-pill__body">
              <%- icon('graduation', 26) %>
              <strong>Coach</strong>
              <small>Je propose mes services</small>
            </div>
          </label>
        </div>
      </div>

      <button type="submit" class="btn btn--primary btn--block btn--lg">Créer mon compte</button>
    </form>

    <p class="auth-foot">Déjà inscrit ? <a href="/auth/login">Se connecter</a></p>
  </div>
</div>

<script>
  // Présélection du rôle depuis l'URL (?role=coach)
  (function () {
    var params = new URLSearchParams(location.search);
    var role = params.get('role');
    if (role) {
      var el = document.querySelector('input[name="role"][value="' + role + '"]');
      if (el) el.checked = true;
    }
  })();
</script>
