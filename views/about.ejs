<section class="tarifs-hero">
  <div class="container">
    <span class="hero__badge"><%= t('home.slogan') %></span>
    <h1 class="tarifs-hero__title"><%= t('about.title') %></h1>
    <p class="tarifs-hero__sub"><%= t('about.sub') %></p>
  </div>
</section>

<section class="container section">
  <div class="section__head">
    <h2 class="section__title"><%= t('about.mission.title') %></h2>
    <p class="section__sub"><%= t('about.mission.sub') %></p>
  </div>

  <div class="features features--6">
    <div class="feature"><div class="feature__icon"><%- icon('shield', 26) %></div><h4><%= t('about.f1.t') %></h4><p><%= t('about.f1.d') %></p></div>
    <div class="feature"><div class="feature__icon"><%- icon('map', 26) %></div><h4><%= t('about.f2.t') %></h4><p><%= t('about.f2.d') %></p></div>
    <div class="feature"><div class="feature__icon"><%- icon('cash', 26) %></div><h4><%= t('about.f3.t') %></h4><p><%= t('about.f3.d') %></p></div>
    <div class="feature"><div class="feature__icon"><%- icon('user', 26) %></div><h4><%= t('about.f4.t') %></h4><p><%= t('about.f4.d') %></p></div>
    <div class="feature"><div class="feature__icon"><%- icon('book', 26) %></div><h4><%= t('about.f5.t') %></h4><p><%= t('about.f5.d') %></p></div>
    <div class="feature"><div class="feature__icon"><%- icon('award', 26) %></div><h4><%= t('about.f6.t') %></h4><p><%= t('about.f6.d') %></p></div>
  </div>
</section>

<section class="section section--alt">
  <div class="container">
    <div class="section__head">
      <h2 class="section__title"><%= t('footer.how') %></h2>
    </div>
    <div class="steps">
      <div class="step"><span class="step__num">1</span><div class="step__icon"><%- icon('users', 26) %></div><h4><%= t('about.s1.t') %></h4><p><%= t('about.s1.d') %></p></div>
      <div class="step"><span class="step__num">2</span><div class="step__icon"><%- icon('search', 26) %></div><h4><%= t('about.s2.t') %></h4><p><%= t('about.s2.d') %></p></div>
      <div class="step"><span class="step__num">3</span><div class="step__icon"><%- icon('graduation', 26) %></div><h4><%= t('about.s3.t') %></h4><p><%= t('about.s3.d') %></p></div>
    </div>
  </div>
</section>

<section class="container section">
  <div class="about-contact">
    <h2 class="section__title"><%= t('about.contact.title') %></h2>
    <p><%- icon('mail', 18) %> <a href="mailto:<%= APP.contact.email %>"><%= APP.contact.email %></a></p>
    <p><%- icon('phone', 18) %> <a href="https://wa.me/<%= APP.contact.whatsapp %>" target="_blank" rel="noopener"><%= APP.contact.phone %> (WhatsApp)</a></p>
    <p><%- icon('pin', 18) %> <%= APP.contact.ville %></p>
  </div>
</section>

<section class="cta-band">
  <div class="container cta-band__inner">
    <h2><%= t('about.join.title') %></h2>
    <p><%= t('about.join.text') %></p>
    <div class="cta-band__actions">
      <a href="/auth/register" class="btn btn--amber btn--lg"><%= t('nav.register') %></a>
      <a href="/tarifs" class="btn btn--glass btn--lg"><%= t('about.seePricing') %></a>
    </div>
  </div>
</section>
