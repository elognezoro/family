<!-- ════════ HERO ════════ -->
<section class="hero">
  <div class="hero__overlay"></div>
  <div class="container hero__content">
    <span class="hero__badge"><%= t('home.slogan') %></span>
    <h1 class="hero__title"><%- t('home.hero.title') %></h1>
    <p class="hero__subtitle"><%= t('home.hero.subtitle') %></p>
    <div class="hero__cta">
      <a href="/auth/register" class="btn btn--primary btn--lg"><%- icon('users', 20) %> <%= t('home.hero.ctaStart') %></a>
      <a href="/parent/recherche" class="btn btn--glass btn--lg"><%- icon('map', 20) %> <%= t('home.hero.ctaMap') %></a>
    </div>
  </div>

  <!-- Bandes défilantes : couverture pays + disciplines -->
  <div class="marquee marquee--flags">
    <div class="marquee__track">
      <% for (let pass = 0; pass < 2; pass++) { %>
        <% flagCodes.forEach(function(code){ %><span class="fi fi-<%= code %>"></span><% }) %>
      <% } %>
    </div>
  </div>
  <div class="marquee marquee--disciplines">
    <div class="marquee__track marquee__track--reverse">
      <% for (let pass = 0; pass < 2; pass++) { %>
        <% disciplineNames.forEach(function(name){ %><span class="chip-disc"><%= name %></span><% }) %>
      <% } %>
    </div>
  </div>
</section>

<!-- ════════ COMPTEURS TEMPS RÉEL ════════ -->
<section class="live-stats">
  <div class="container live-stats__inner">
    <span class="live-stats__badge"><span class="live-dot"></span> <%= t('home.live.badge') %></span>
    <div class="live-stats__grid">
      <div class="live-stat">
        <div class="live-stat__icon"><%- icon('eye', 24) %></div>
        <% if (dbOk) { %><div class="live-stat__num" data-count="<%= visits %>" data-live="visits">0</div><% } else { %><div class="live-stat__num" data-live="visits">—</div><% } %>
        <div class="live-stat__label"><%= t('home.live.visits') %></div>
      </div>
      <div class="live-stat">
        <div class="live-stat__icon"><%- icon('users', 24) %></div>
        <% if (dbOk) { %><div class="live-stat__num" data-count="<%= totalUsers %>" data-live="users">0</div><% } else { %><div class="live-stat__num" data-live="users">—</div><% } %>
        <div class="live-stat__label"><%= t('home.live.accounts') %></div>
      </div>
    </div>
  </div>
</section>

<!-- ════════ STATISTIQUES ════════ -->
<section class="stats">
  <div class="container stats__grid">
    <div class="stat">
      <div class="stat__icon"><%- icon('graduation', 24) %></div>
      <% if (dbOk) { %><div class="stat__num" data-count="<%= stats.coachs %>">0</div><% } else { %><div class="stat__num">—</div><% } %>
      <div class="stat__label"><%= t('home.stats.coaches') %></div>
    </div>
    <div class="stat">
      <div class="stat__icon"><%- icon('book', 24) %></div>
      <div class="stat__num" data-count="<%= stats.disciplines %>">0</div>
      <div class="stat__label"><%= t('home.stats.disciplines') %></div>
    </div>
    <div class="stat">
      <div class="stat__icon"><%- icon('map', 24) %></div>
      <div class="stat__num" data-count="<%= stats.pays %>">0</div>
      <div class="stat__label"><%= t('home.stats.countries') %></div>
    </div>
    <div class="stat">
      <div class="stat__icon"><%- icon('cash', 24) %></div>
      <div class="stat__num" data-count="<%= stats.operateurs %>">0</div>
      <div class="stat__label"><%= t('home.stats.operators') %></div>
    </div>
  </div>
</section>

<!-- ════════ COACHS EN VEDETTE ════════ -->
<% if (featuredCoaches && featuredCoaches.length) { %>
<section class="container section">
  <div class="section__head">
    <h2 class="section__title"><%= t('home.featured.title') %></h2>
    <p class="section__sub"><%= t('home.featured.sub') %></p>
  </div>
  <div class="showcase">
    <% featuredCoaches.forEach(function(c){
         var topDisc = c.disciplines[0] ? disciplinesData.disciplineLabel(c.disciplines[0].disciplineId) : t('home.featured.spec');
         var note = c.note && c.note > 0 ? c.note : 4.8; %>
      <div class="showcase-card">
        <div class="showcase-card__head">
          <div class="showcase-card__avatar">
            <% if (c.user.photo) { %><img src="<%= c.user.photo %>" alt=""><% } else { %><%= c.user.name.charAt(0) %><% } %>
          </div>
          <div>
            <div class="showcase-card__name">
              <%= c.user.name %>
              <% if (c.certifie) { %><span class="badge badge--certif"><%- icon('award', 12) %></span><% } %>
            </div>
            <div class="showcase-card__spec"><%= topDisc %></div>
          </div>
        </div>
        <div class="showcase-card__meta">
          <span><%- icon('pin', 14) %> <%= c.commune || 'Côte d\'Ivoire' %></span>
          <span class="rating"><%- icon('star', 14) %> <%= note.toFixed(1) %></span>
        </div>
        <div class="showcase-card__tags">
          <% [...new Set(c.disciplines.map(function(d){ return disciplinesData.disciplineLabel(d.disciplineId); }))].slice(0,3).forEach(function(lbl){ %><span class="tag"><%= lbl %></span><% }) %>
        </div>
        <a href="/parent/recherche" class="btn btn--ghost btn--sm btn--block"><%= t('home.featured.view') %></a>
      </div>
    <% }) %>
  </div>
</section>
<% } %>

