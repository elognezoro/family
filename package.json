{
  "name": "eduweb-family-coaching",
  "version": "1.0.0",
  "description": "EduWeb — Family & Coaching : plateforme de mise en relation familles / coachs scolaires en Côte d'Ivoire",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:reset": "prisma db push --force-reset && node prisma/seed.js",
    "setup": "prisma generate && prisma db push && node prisma/seed.js",
    "postinstall": "prisma generate",
    "vercel-build": "prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [
    "education",
    "coaching",
    "cote-divoire",
    "express",
    "prisma"
  ],
  "author": "EduWeb",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@vercel/blob": "^2.4.0",
    "bcryptjs": "^2.4.3",
    "cookie-session": "^2.1.1",
    "country-state-city": "^3.2.1",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.1",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.18.1",
    "multer": "^1.4.5-lts.1",
    "resend": "^4.0.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
